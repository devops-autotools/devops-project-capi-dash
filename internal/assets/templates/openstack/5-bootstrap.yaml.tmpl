apiVersion: bootstrap.cluster.x-k8s.io/v1beta1
kind: KubeadmConfigTemplate
metadata:
  name: {{ .ClusterName }}-worker-config
  namespace: {{ .Namespace }}
spec:
  template:
    spec:
      joinConfiguration:
        nodeRegistration:
          kubeletExtraArgs:
            cloud-provider: external
            node-ip: '{{ `{{ ds.ec2_metadata.local_ipv4 }}` }}'
            provider-id: openstack:///{{ `{{ instance_id }}` }}
            node-labels: capi-internal/workergroup=default
          name: '{{ `{{ local_hostname }}` }}'
