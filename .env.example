# ============================================================
# CAPI Dashboard - Environment Variables Example
# Copy file này thành .env và điền giá trị thực
# ============================================================

# Kubernetes
KUBECONFIG=~/.kube/config

# Backend port (default: 8080)
PORT=8080

# OpenStack credentials (nếu dùng username/password)
OS_AUTH_URL=https://<keystone-url>:5000
OS_USERNAME=
OS_PASSWORD=
OS_PROJECT_NAME=
OS_DOMAIN_NAME=Default

# OpenStack credentials (nếu dùng application credential)
# OS_APPLICATION_CREDENTIAL_ID=
# OS_APPLICATION_CREDENTIAL_SECRET=
